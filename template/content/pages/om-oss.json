              {
                "q": "Koster det noe?",
                "a": "<p>Nei. Alt er åpen kildekode, og siden kan hostes gratis.</p>"
              },
              {
                "q": "Hvordan kommer jeg i gang?",
                "a": "<p>Klon malen, åpne <strong>/admin</strong>, og bygg siden i nettleseren.</p>"
