      "color": {
        "bg": "#0b0e14",
        "surface": "#151a23",
        "text": "#e8eaf0",
        "accent": "#7c5cff"
      },
      "font": {
        "heading": "'Courier New', monospace",
        "body": "Georgia, 'Times New Roman', serif"
      },
      "radius": {
        "sm": "6px",
        "md": "12px"
      },
      "space": {
        "section": "clamp(3rem, 8vw, 6rem)"
      }
    }
  },
  "pages": [
    {
      "id": "hjem",
      "title": "Hjem",
      "path": "/",
      "file": "content/pages/hjem.json"
