{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urd.dev/schema/site.schema.json",
  "title": "Urd site.json",
  "description": "Nettstedets rot: identitet, sideregister, navigasjon, grid og tema. Kontrakten er beskrevet i docs/SKJEMA.md.",
  "type": "object",
  "required": ["schemaVersion", "site", "grid", "theme", "pages", "nav"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "site": {
      "type": "object",
      "required": ["title", "lang"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "lang": { "type": "string", "minLength": 2 },
        "description": { "type": "string" },
        "icon": { "type": "string", "description": "Nettstedsikon (favicon): sti i media/ (data-URL i utkast). Additivt felt fra v0.5." },
        "setup": { "type": "boolean", "description": "Additivt fra v0.6: true i malens standardinnhold utløser oppsettsveiviseren i admin; veiviseren fjerner feltet ved fullføring. Erstatter den gamle strengmatchingen på malens standardnavn." }
      }
    },
    "breakpoints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mobile": { "type": "integer", "minimum": 200, "description": "Maks bredde (px) som regnes som mobil" }
      }
    },
    "grid": { "$ref": "#/$defs/grid" },
    "theme": {
      "type": "object",
      "required": ["version", "tokens"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "tokens": {
          "type": "object",
          "description": "Grupper av design-tokens; mappes til CSS-variabler --urd-<gruppe>-<navn>",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        },
        "scheme": {
          "enum": ["light", "dark"],
          "default": "light",
          "description": "Hovedtemaets lyshet (additivt fra v0.6): hva lys/mørk-bryteren og prefers-color-scheme regner hovedtokens som."
        },
        "alt": {
          "type": "object",
          "description": "Alternativt tema for lys/mørk-bryteren (additivt fra v0.6): token-grupper som overstyrer hovedtokens i motsatt modus av scheme. Finnes feltet, viser nav-en bryteren.",
          "required": ["tokens"],
          "additionalProperties": false,
          "properties": {
            "tokens": {
              "type": "object",
              "description": "Samme form som theme.tokens; utelatte verdier arver hovedtemaet",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "pages": {
      "type": "array",
      "description": "Sideregisteret - nav, ruting og adminpaneler deriveres herfra",
      "items": {
        "type": "object",
        "required": ["id", "title", "path", "file"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "title": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "pattern": "^/" },
          "file": { "type": "string", "pattern": "^content/pages/.+\\.json$" }
        }
      }
    },
    "nav": {
      "type": "object",
      "required": ["version", "items"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "layout": {
          "enum": ["left", "center", "right"],
          "default": "right",
          "description": "Menypunktenes plassering (logoen står alltid først). Additivt felt fra v0.5."
        },
        "sticky": {
          "type": "boolean",
          "default": true,
          "description": "Menyen følger med når man blar nedover (false = ligger kun øverst). Additivt felt fra v0.5."
        },
        "variant": {
          "enum": ["bar", "floating", "side-left", "side-right"],
          "default": "bar",
          "description": "Menyens form (additivt fra v0.6): bar = stripe i full bredde, floating = pille som svever over innholdet, side-left/side-right = fast kolonne langs kanten (mobil faller tilbake til topplinje med burger)."
        },
        "style": {
          "type": "object",
          "description": "Menyens utseende (additivt fra v0.5). Utelatte felt = standard.",
          "additionalProperties": false,
          "properties": {
            "bg": { "type": "string", "description": "Bakgrunnsfarge: theme-token eller rå farge" },
            "bgOpacity": { "type": "number", "minimum": 0, "maximum": 1, "description": "Bakgrunnens dekkevne (0 = gjennomsiktig)" },
            "blur": { "type": "boolean", "default": true, "description": "Uskarphet bak menyen" },
            "textColor": { "type": "string", "description": "Tekstfarge i menyen (tom = temaets tekstfarge)" },
            "hover": {
              "enum": ["standard", "underline", "pill", "lift"],
              "default": "standard",
              "description": "Hover-stil for menylenkene (additivt fra v0.6): standard = aksentfarge, underline = glidende understrek, pill = avrundet bakgrunn, lift = løft med glød."
            },
            "glow": {
              "type": "boolean",
              "default": false,
              "description": "Glød rundt den flytende pillen (additivt fra v0.6; gjelder kun variant floating)."
            },
            "topGap": {
              "type": "boolean",
              "default": true,
              "description": "Luft over den flytende pillen (additivt fra v0.6; false = pillen ligger helt i toppen)."
            },
            "image": { "type": "string", "description": "Bakgrunnsbilde i menyen (additivt fra v0.6): sti i media/ (data-URL i utkast). bg/bgOpacity legger seg som slør over bildet." },
            "imageOpacity": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 1,
              "description": "Bildestyrke (additivt fra v0.6): under 1 tones bildet mot bakgrunnsfargen."
            },
            "imageY": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "default": 50,
              "description": "Bildeutsnitt i høyden (additivt fra v0.6): 0 = toppen av bildet, 100 = bunnen."
            }
          }
        },
        "logo": {
          "type": "object",
          "required": ["type", "value"],
          "additionalProperties": false,
          "properties": {
            "type": { "enum": ["text", "image", "both"], "description": "both = bilde + tekst (additivt fra v0.5)" },
            "value": { "type": "string", "description": "Tekst (type text/both) eller bilde-URL (type image)" },
            "image": { "type": "string", "description": "Bilde-URL når type er both" },
            "size": { "type": "number", "minimum": 12, "maximum": 128, "description": "Bildehøyde i px (standard 32)" },
            "order": { "enum": ["image-first", "text-first"], "default": "image-first", "description": "Rekkefølge når type er both" },
            "font": { "type": "string", "description": "Fontstabel for logoteksten (tom = temaets overskriftsfont)" },
            "textSize": { "type": "number", "minimum": 8, "maximum": 96, "description": "Tekststørrelse i px (tom = arv)" },
            "bold": { "type": "boolean", "default": true },
            "italic": { "type": "boolean", "default": false },
            "radius": { "type": "number", "minimum": 0, "maximum": 64, "description": "Bildets avrunding i px" }
          }
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label"],
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string", "minLength": 1 },
              "page": { "$ref": "#/$defs/id", "description": "Id fra sideregisteret" },
              "href": { "type": "string", "description": "Ekstern lenke - brukes når page ikke er satt" },
              "children": {
                "type": "array",
                "description": "Undermeny, ett nivå (additivt fra v0.6). Et punkt med children men uten page/href er en ren åpner (hele punktet åpner undermenyen); med eget mål vises lenken pluss en pilknapp.",
                "items": {
                  "type": "object",
                  "required": ["label"],
                  "additionalProperties": false,
                  "properties": {
                    "label": { "type": "string", "minLength": 1 },
                    "page": { "$ref": "#/$defs/id", "description": "Id fra sideregisteret" },
                    "href": { "type": "string", "description": "Ekstern lenke - brukes når page ikke er satt" }
                  },
                  "oneOf": [
                    { "required": ["page"] },
                    { "required": ["href"] }
                  ]
                }
              }
            },
            "anyOf": [
              { "required": ["page"] },
              { "required": ["href"] },
              { "required": ["children"] }
            ],
            "not": { "required": ["page", "href"] }
          }
        }
      }
    },
    "footer": {
      "type": "object",
      "description": "Delt footer på alle sider (additivt felt fra v0.5). Utelatt/skjult = ingen footer.",
      "required": ["version"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "show": { "type": "boolean", "default": false },
        "text": { "type": "string", "description": "Linjer skilt med linjeskift; hver linje blir et avsnitt" },
        "align": { "enum": ["left", "center", "right"], "default": "center" }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "grid": {
      "type": "object",
      "required": ["size"],
      "additionalProperties": false,
      "description": "Snappeverktøy (fra site-schemaVersion 2): kvadratiske ruter. Påvirker aldri plassering.",
      "properties": {
        "size": { "type": "number", "minimum": 2, "maximum": 256, "description": "Rutestørrelse i px (mindre = tettere)" },
        "snap": { "type": "boolean", "default": true }
      }
    }
  }
}
